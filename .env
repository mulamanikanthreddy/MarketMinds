# ============================================================
#  MarketMind AI — .env.example
#
#  HOW TO USE:
#  1. Copy this file and rename it to just:  .env
#  2. Replace each "your_key_here" with your real API key
#  3. NEVER share the .env file or upload it anywhere
#  4. Add ".env" to your .gitignore file
# ============================================================

# Your Anthropic (Claude) API Key
# Get it from: https://console.anthropic.com
ANTHROPIC_KEY=your_anthropic_key_here

# Your OpenAI API Key
# Get it from: https://platform.openai.com/api-keys
OPENAI_KEY=your_openai_key_here

# Your News API Key
# Get it from: https://newsapi.org/register
NEWS_KEY=your_news_api_key_here

# Port the server runs on (3000 is standard, no need to change)
PORT=3000
